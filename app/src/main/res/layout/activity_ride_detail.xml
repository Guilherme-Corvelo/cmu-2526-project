<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Car photo -->
        <ImageView
            android:id="@+id/iv_car_photo"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:src="@android:drawable/ic_menu_directions"
            android:layout_marginBottom="16dp"/>

        <!-- Driver info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_driver_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="Driver Name"/>

            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F9A825"
                android:textSize="16sp"
                android:text="★ 5.0"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:text="Origin → Destination"/>

        <TextView
            android:id="@+id/tv_departure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"
            android:text="Mon, 01 Jan 2026  09:00"/>

        <TextView
            android:id="@+id/tv_periodic_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="italic"
            android:textColor="#388E3C"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:text="This is a periodic ride (Weekly)"/>

        <CheckBox
            android:id="@+id/cb_recurring_booking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book for every occurrence"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_seats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:text="3 of 4 seats available"/>

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:text="€5.00 per seat"/>
        </LinearLayout>

        <!-- Weather Preferences Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_weather_prefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Weather Preferences"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_weather_type"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Auto-cancel if..."
                    android:layout_marginBottom="8dp">

                    <AutoCompleteTextView
                        android:id="@+id/actv_weather_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_threshold"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Temperature Threshold (°C)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_threshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Weather warning banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tv_weather_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/warning_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/tv_weather_text"
                android:padding="12dp"
                android:text="⚠ This ride may be cancelled due to weather conditions"
                android:textColor="@color/warning_text"/>
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tv_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:textStyle="bold"
            android:text="Pending request"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:id="@+id/layout_request_actions">

            <Button
                android:id="@+id/btn_accept_request"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accept"/>

            <Button
                android:id="@+id/btn_reject_request"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reject"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_view_passenger_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="View passenger profile"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_book"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book this ride"
            android:padding="16dp"/>

        <Button
            android:id="@+id/btn_start_ride"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Ride"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="#E8F5E9"
            app:rippleColor="#C8E6C9"
            android:textColor="#2E7D32"/>

        <Button
            android:id="@+id/btn_finish_ride"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finish Ride"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="#E3F2FD"
            app:rippleColor="#BBDEFB"
            android:textColor="#1565C0"/>

        <Button
            android:id="@+id/btn_cancel_ride"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel Ride"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="#FFEBEE"
            app:rippleColor="#FFCDD2"
            android:textColor="#C62828"/>

    </LinearLayout>
</ScrollView>
