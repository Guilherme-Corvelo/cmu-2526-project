rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User can create and update their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        // Allow a driver/system to increase a user's balance (for refunds/payments)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
         request.resource.data.balance > resource.data.balance)
      );
    }

    match /rides/{rideId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.driverId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        // Passengers can update seatsAvailable during the booking transaction
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seatsAvailable', 'status'])
      );
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.driverId || request.auth.uid == resource.data.passengerId);
      allow create: if request.auth != null && (
        request.resource.data.passengerId == request.auth.uid ||
        request.resource.data.driverId == request.auth.uid
      );
      allow update: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        resource.data.passengerId == request.auth.uid
      );
      // Request cancellation/release removes the synthetic booking that was
      // created when a driver accepted a passenger request. Either involved
      // party may trigger that cleanup, but unrelated users may not delete it.
      allow delete: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        resource.data.passengerId == request.auth.uid
      );
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.passengerId == request.auth.uid ||
        request.resource.data.driverId == request.auth.uid
      );
    }

    match /ride_requests/{requestId} {
      allow read: if request.auth != null;
      // Passenger can create a request. A driver who completed a periodic
      // passenger request may publish the next occurrence only when it points
      // back to that completed request.
      allow create: if request.auth != null && (
        request.resource.data.passengerId == request.auth.uid ||
        (request.resource.data.periodic == true &&
         request.resource.data.status == "OPEN" &&
         request.resource.data.driverId == null &&
         request.resource.data.previousRequestId is string &&
         exists(/databases/$(database)/documents/ride_requests/$(request.resource.data.previousRequestId)) &&
         get(/databases/$(database)/documents/ride_requests/$(request.resource.data.previousRequestId)).data.periodic == true &&
         get(/databases/$(database)/documents/ride_requests/$(request.resource.data.previousRequestId)).data.status == "COMPLETED" &&
         get(/databases/$(database)/documents/ride_requests/$(request.resource.data.previousRequestId)).data.driverId == request.auth.uid &&
         get(/databases/$(database)/documents/ride_requests/$(request.resource.data.previousRequestId)).data.passengerId == request.resource.data.passengerId)
      );
      // Involved parties (or any driver for OPEN requests) can update status
      allow update: if request.auth != null && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        resource.data.status == "OPEN"
      );
    }
  }
}
